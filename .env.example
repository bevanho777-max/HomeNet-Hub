# HomeNet Hub — environment secrets.
# Copy to `.env` (which is .gitignored) and fill in your own values.
# In the default DEMO config none of these are required — the panel runs with
# synthetic data. You only need them once you switch a target to a real backend.

# Read-only Postgres DSN for a `sql` token collector (see config/targets.yaml).
# Use a READ-ONLY account. Host/db/credentials are yours to fill in.
PG_DSN=postgresql://readonly:CHANGE_ME@db.example.local:5432/tokens

# Shared secret(s) for `http_push` targets. The variable name must match the
# target's `token_env` in targets.yaml (one per push target). Generate with:
#   openssl rand -hex 32
PUSH_TOKEN_GPU1=CHANGE_ME_long_random_string

# Optional: bot token for the built-in `probe_telegram` exec command.
# TELEGRAM_BOT_TOKEN=

# Optional: override the listen port (default 3100).
# PORT=3100
